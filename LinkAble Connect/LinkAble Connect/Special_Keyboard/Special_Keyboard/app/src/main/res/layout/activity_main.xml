<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#4F46E5"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hand Signal Keyboard"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="A custom mobile keyboard built to support hand-signal based input in a clearer, faster, and more accessible way."
                android:textColor="#E8EAFE"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FFFFFF"
                android:paddingLeft="14dp"
                android:paddingTop="8dp"
                android:paddingRight="14dp"
                android:paddingBottom="8dp"
                android:text="Keyboard is ready to activate"
                android:textColor="#4F46E5"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Why this app card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why this app was built"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="This app was created to provide a specialized keyboard interface for users who need a hand-signal based or symbol-based typing experience instead of a normal text keyboard. The purpose is to make communication easier through a guided custom layout with structured pages and dedicated keys."
                android:textColor="#4B5563"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="The keyboard service already handles the key presses and typing logic. This main app screen is mainly used to explain the system, guide the user, and help them enable the keyboard correctly."
                android:textColor="#4B5563"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- How it works -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How the keyboard works"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="• Each hand signal key is mapped to a code in the keyboard XML layouts."
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="• When a key is pressed, the keyboard service detects the key code and inserts the related text or symbol."
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="• The keyboard supports page switching, language switching, backspace, space, and enter actions."
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="• The app itself is the setup and guide interface, while the actual typing happens through the keyboard service."
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Setup steps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup steps"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="1. Open keyboard settings"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Hand Signal Keyboard from the list of available keyboards."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="2. Select it as your default input method"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose this keyboard whenever you want to type using the special hand-signal layout."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="3. Start using it in any text field"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use it in chat apps, notes, browsers, search bars, and supported text inputs."
                android:textColor="#4B5563"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- FAQ dropdowns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick help"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ExpandableListView
                android:id="@+id/faqListView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:groupIndicator="@null"
                android:divider="#E5E7EB"
                android:dividerHeight="1dp" />
        </LinearLayout>

        <!-- Navigation buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore more"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnImeSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#4F46E5"
                android:text="Open Keyboard Settings"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnGuidePage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#E0E7FF"
                android:text="Open User Guide"
                android:textAllCaps="false"
                android:textColor="#312E81"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAboutPage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#EDE9FE"
                android:text="About This Project"
                android:textAllCaps="false"
                android:textColor="#5B21B6"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="This screen is for setup, guidance, and navigation. The actual typing is handled by the keyboard service."
            android:textColor="#6B7280"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>