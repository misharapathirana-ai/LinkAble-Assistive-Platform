<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/imeRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#ECECEC"
    android:paddingLeft="0dp"
    android:paddingTop="2dp"
    android:paddingRight="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/signPreviewBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:padding="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/signPreviewIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:contentDescription="Last sign preview" />
        </FrameLayout>

        <com.example.specialkeyboard.SmallIconKeyboardView
            android:id="@+id/keyboardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ECECEC"
            android:keyBackground="@android:color/transparent"
            android:padding="0dp" />

        <!-- Static bottom bar -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginLeft="6dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="100">


            <TextView
                android:id="@+id/btnLanguage"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="12"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="සි"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="10"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="◀"
                android:textColor="#111111"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="10"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="▶"
                android:textColor="#111111"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/btnSpace"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="38"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_space"
                android:gravity="center"
                android:text="space"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/btnEnter"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="10"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="↵"
                android:textColor="#111111"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="10"
                android:layout_marginRight="4dp"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="✓"
                android:textColor="#111111"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="10"
                android:background="@drawable/key_bg_bottom_small"
                android:gravity="center"
                android:text="⌫"
                android:textColor="#111111"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>